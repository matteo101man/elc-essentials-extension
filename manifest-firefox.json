{
  "manifest_version": 2,
  "name": "ELC Essentials",
  "version": "3.3.0",
  "description": "ELC Essentials for D2L Brightspace: Practice Tests, Course Schedule, Grade Calculator",
  "author": "Matteo Garza",
  "browser_specific_settings": {
    "gecko": {
      "id": "elc-essentials@matteogarza",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_title": "ELC Essentials",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "https://uga.view.usg.edu/*",
    "https://athena-prod.uga.edu/*",
    "https://api.openai.com/*",
    "https://raw.githubusercontent.com/*",
    "https://gist.githubusercontent.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://uga.view.usg.edu/*",
        "https://athena-prod.uga.edu/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
